.admin-page {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 280px 1fr;
  background: radial-gradient(circle at top, #2b2108, #050505 45%, #000);
  color: #f8f1dc;
}

.admin-sidebar {
  padding: 28px;
  background: rgba(0, 0, 0, 0.72);
  border-right: 1px solid rgba(255, 215, 130, 0.18);
  display: flex;
  flex-direction: column;
  gap: 28px;
}

.admin-logo {
  display: flex;
  align-items: center;
  gap: 14px;
}

.logo-icon {
  width: 54px;
  height: 54px;
  border-radius: 18px;
  display: grid;
  place-items: center;
  background: linear-gradient(135deg, #d4af37, #7a4b00);
  color: #080808;
  font-size: 26px;
  font-weight: 900;
}

.admin-logo h2 {
  margin: 0;
  font-size: 1.6rem;
}

.admin-logo span {
  color: #d4af37;
  font-weight: 700;
  letter-spacing: 2px;
}

.admin-menu {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.admin-menu a {
  padding: 14px 16px;
  border-radius: 16px;
  color: #cabf9a;
  font-weight: 800;
}

.admin-menu a.active,
.admin-menu a:hover {
  background: rgba(212, 175, 55, 0.16);
  color: #ffd86b;
}

.logout-admin {
  margin-top: auto;
  height: 50px;
  border: 1px solid rgba(255, 216, 107, 0.45);
  border-radius: 16px;
  background: transparent;
  color: #ffd86b;
  font-weight: 900;
  cursor: pointer;
}

.admin-main {
  padding: 34px;
}

.admin-header {
  padding: 30px;
  border-radius: 28px;
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.18), rgba(255, 255, 255, 0.04));
  border: 1px solid rgba(255, 215, 130, 0.16);
  box-shadow: 0 24px 70px rgba(0, 0, 0, 0.36);
}

.admin-badge {
  color: #ffd86b;
  font-weight: 900;
  letter-spacing: 3px;
}

.admin-header h1 {
  margin: 12px 0;
  font-size: 3rem;
}

.admin-header p {
  margin: 0;
  color: #d7cfb8;
}

.admin-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
  margin: 24px 0;
}

.admin-stats article,
.module-card {
  background: rgba(255, 255, 255, 0.055);
  border: 1px solid rgba(255, 215, 130, 0.13);
  border-radius: 24px;
  padding: 22px;
}

.admin-stats strong {
  display: block;
  font-size: 1.5rem;
  color: #ffd86b;
}

.admin-stats span,
.module-card p {
  color: #cfc6aa;
}

.modules-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(180px, 1fr));
  gap: 18px;
}

.module-card {
  transition: 0.25s ease;
}

.module-card:hover {
  transform: translateY(-4px);
  border-color: rgba(255, 216, 107, 0.45);
}

.module-icon {
  font-size: 2rem;
}

.module-card h3 {
  margin: 14px 0 8px;
}

.module-card button {
  margin-top: 14px;
  width: 100%;
  height: 42px;
  border: none;
  border-radius: 14px;
  background: linear-gradient(135deg, #ffd86b, #b88416);
  color: #111;
  font-weight: 900;
  cursor: pointer;
}

@media (max-width: 1000px) {
  .admin-page {
    grid-template-columns: 1fr;
  }

  .admin-sidebar {
    border-right: none;
    border-bottom: 1px solid rgba(255, 215, 130, 0.18);
  }

  .modules-grid,
  .admin-stats {
    grid-template-columns: 1fr;
  }
}

