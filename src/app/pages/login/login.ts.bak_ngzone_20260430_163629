п»ҝimport { CommonModule } from '@angular/common';
import { Component, EventEmitter, Output } from '@angular/core';
import { FormsModule } from '@angular/forms';
import { AuthService } from '../../services/auth';

@Component({
  selector: 'app-login',
  imports: [CommonModule, FormsModule],
  templateUrl: './login.html',
  styleUrl: './login.css'
})
export class Login {
  @Output() loginCorrecto = new EventEmitter<string>();

  modo: 'login' | 'registro' = 'login';

  userName = '';
  password = '';
  nombreCompleto = '';
  correoElectronico = '';
  telefono = '';

  mensaje = '';
  tipoMensaje: 'ok' | 'error' = 'error';
  cargando = false;

  constructor(private authService: AuthService) {}

  cambiarModo(modo: 'login' | 'registro') {
    this.modo = modo;
    this.mensaje = '';
    this.tipoMensaje = 'error';
    this.cargando = false;
  }

  soloNumeros(event: KeyboardEvent) {
    const teclasPermitidas = ['Backspace', 'Tab', 'ArrowLeft', 'ArrowRight', 'Delete', 'Home', 'End'];
    const tecla = event.key;

    if (teclasPermitidas.includes(tecla)) return;

    if (!/^[0-9]$/.test(tecla)) {
      event.preventDefault();
      return;
    }

    const telefonoLimpio = (this.telefono || '').replace(/\D/g, '');

    if (telefonoLimpio.length >= 10) {
      event.preventDefault();
    }
  }

  limitarTelefono() {
    this.telefono = (this.telefono || '').replace(/\D/g, '').slice(0, 10);
  }

  soloLetras(event: KeyboardEvent) {
    const teclasPermitidas = ['Backspace', 'Tab', 'ArrowLeft', 'ArrowRight', 'Delete', 'Home', 'End'];
    const tecla = event.key;

    if (teclasPermitidas.includes(tecla)) return;

    if (!/^[A-Za-zГҒГүГҚГ“ГҡГЎГ©ГӯГіГәГ‘ГұГңГј\s'-]$/.test(tecla)) {
      event.preventDefault();
    }
  }

  limpiarNombreCompleto() {
    this.nombreCompleto = (this.nombreCompleto || '')
      .replace(/[^A-Za-zГҒГүГҚГ“ГҡГЎГ©ГӯГіГәГ‘ГұГңГј\s'-]/g, '')
      .replace(/\s+/g, ' ')
      .slice(0, 80);
  }

  private mostrarError(mensaje: string) {
    this.cargando = false;
    this.tipoMensaje = 'error';
    this.mensaje = mensaje;
  }

  private mostrarOk(mensaje: string) {
    this.cargando = false;
    this.tipoMensaje = 'ok';
    this.mensaje = mensaje;
  }

  private extraerMensajeError(error: any, mensajeDefault: string): string {
    if (error?.status === 0) {
      return 'No se pudo conectar con el servidor. Verifica que el backend estГ© levantado en https://localhost:44398.';
    }

    if (typeof error?.error === 'string') {
      return error.error;
    }

    if (error?.error?.mensaje) {
      return error.error.mensaje;
    }

    return mensajeDefault;
  }

  private validarRegistro(): boolean {
    const nombreRegex = /^[A-Za-zГҒГүГҚГ“ГҡГЎГ©ГӯГіГәГ‘ГұГңГј\s'-]{2,80}$/;
    const correoRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const telefonoRegex = /^09[0-9]{8}$/;

    this.limitarTelefono();
    this.limpiarNombreCompleto();

    if (!this.userName.trim()) {
      this.mostrarError('Por favor ingresa un nombre de usuario.');
      return false;
    }

    if (this.userName.trim().length < 4) {
      this.mostrarError('El usuario debe tener al menos 4 caracteres.');
      return false;
    }

    if (!this.nombreCompleto.trim()) {
      this.mostrarError('Por favor ingresa tu nombre completo.');
      return false;
    }

    if (!nombreRegex.test(this.nombreCompleto.trim())) {
      this.mostrarError('El nombre completo solo debe contener letras y espacios. No se permiten nГәmeros.');
      return false;
    }

    if (!this.correoElectronico.trim()) {
      this.mostrarError('Por favor ingresa tu correo electrГіnico.');
      return false;
    }

    if (!correoRegex.test(this.correoElectronico.trim())) {
      this.mostrarError('Ingresa un correo electrГіnico vГЎlido.');
      return false;
    }

    if (!this.telefono.trim()) {
      this.mostrarError('Por favor ingresa tu telГ©fono.');
      return false;
    }

    if (!telefonoRegex.test(this.telefono.trim())) {
      this.mostrarError('El telГ©fono debe tener exactamente 10 dГӯgitos y empezar con 09.');
      return false;
    }

    if (!this.password.trim()) {
      this.mostrarError('Por favor ingresa una contraseГұa.');
      return false;
    }

    if (this.password.length < 5) {
      this.mostrarError('La contraseГұa debe tener al menos 5 caracteres.');
      return false;
    }

    return true;
  }

  iniciarSesion() {
    this.mensaje = '';

    if (!this.userName.trim() || !this.password.trim()) {
      this.mostrarError('Ingresa usuario y contraseГұa para continuar.');
      return;
    }

    this.cargando = true;

    this.authService.login({
      userName: this.userName.trim(),
      password: this.password
    }).subscribe({
      next: (response) => {
        this.mostrarOk(
          response.rol === 'ADMIN'
            ? 'Bienvenido administrador. Entrando al panel...'
            : 'Bienvenido. Iniciando sesiГіn...'
        );

        setTimeout(() => {
          this.loginCorrecto.emit(response.rol);
        }, 700);
      },
      error: (error) => {
        const mensaje = this.extraerMensajeError(
          error,
          'No se encontrГі el usuario o la contraseГұa es incorrecta. Si no tienes cuenta, crea una cuenta primero.'
        );

        this.mostrarError(mensaje);
      }
    });
  }

  async crearCuenta() {
    this.mensaje = '';

    if (!this.validarRegistro()) return;

    this.cargando = true;

    const payload = {
      userName: this.userName.trim(),
      password: this.password,
      nombreCompleto: this.nombreCompleto.replace(/\s+/g, ' ').trim(),
      correoElectronico: this.correoElectronico.trim(),
      telefono: this.telefono.replace(/\D/g, '').slice(0, 10)
    };

    try {
      const response = await fetch('https://localhost:44398/api/Auth/register', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(payload)
      });

      let data: any = null;

      try {
        data = await response.json();
      } catch {
        data = null;
      }

      if (!response.ok) {
        this.cargando = false;
        this.tipoMensaje = 'error';
        this.mensaje = data?.mensaje || 'No se pudo crear la cuenta. Revisa usuario, correo o telГ©fono.';
        return;
      }

      this.cargando = false;
      this.password = '';
      this.tipoMensaje = 'ok';
      this.mensaje = 'Cuenta creada correctamente. QuГ©date aquГӯ o cambia a Iniciar sesiГіn para entrar con tu usuario.';
    } catch {
      this.cargando = false;
      this.tipoMensaje = 'error';
      this.mensaje = 'No se pudo conectar con el servidor. Verifica que el backend estГ© levantado en https://localhost:44398.';
    }
  }
}

