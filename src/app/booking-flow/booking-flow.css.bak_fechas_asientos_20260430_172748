:host {
  display: block;
  background: linear-gradient(180deg, #f2f5ff, #ffffff);
  min-height: 100vh;
  color: #12004d;
}

.booking-flow-page {
  width: min(1180px, calc(100% - 36px));
  margin: 0 auto;
  padding: 46px 0 80px;
}

.flow-header {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 24px;
  align-items: center;
  margin-bottom: 28px;
}

.back-btn,
.primary-btn,
.secondary-btn {
  border: none;
  border-radius: 18px;
  font-weight: 900;
  cursor: pointer;
}

.back-btn {
  padding: 18px 24px;
  background: white;
  box-shadow: 0 16px 36px rgba(18, 0, 77, 0.13);
  color: #12004d;
}

.flow-badge {
  display: inline-flex;
  background: #ebe5ff;
  color: #6d4aff;
  padding: 10px 18px;
  border-radius: 999px;
  font-weight: 900;
}

.flow-header h1 {
  margin: 12px 0 8px;
  font-size: 2.4rem;
}

.flow-header p {
  margin: 0;
  color: #52617f;
  font-weight: 600;
}

.flight-summary,
.steps,
.step-content {
  background: white;
  border-radius: 28px;
  box-shadow: 0 22px 50px rgba(18, 0, 77, 0.1);
  padding: 28px;
  margin-bottom: 24px;
}

.route {
  display: grid;
  grid-template-columns: 1fr 180px 1fr;
  align-items: center;
  text-align: center;
  gap: 20px;
  margin-bottom: 26px;
}

.route strong {
  font-size: 2rem;
  display: block;
}

.route span {
  color: #68728e;
  font-weight: 700;
}

.plane-line {
  color: #ff2e74;
  font-size: 2rem;
  border-top: 3px solid #ff2e74;
  border-bottom: 3px solid transparent;
}

.flight-data {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16px;
}

.flight-data article {
  background: #f6f7ff;
  border-radius: 18px;
  padding: 18px;
}

.flight-data span {
  color: #737d99;
  font-weight: 800;
  display: block;
  margin-bottom: 8px;
}

.steps {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 16px;
}

.step {
  background: #f2f4ff;
  border-radius: 18px;
  padding: 18px;
  text-align: center;
  font-weight: 900;
  border: 2px solid transparent;
}

.step span {
  width: 38px;
  height: 38px;
  display: inline-grid;
  place-items: center;
  border-radius: 50%;
  background: #dbe2ff;
  color: #12004d;
  margin-bottom: 8px;
}

.step.active {
  background: #fff1f7;
  border-color: #ff2e74;
}

.step.active span,
.step.done span {
  background: linear-gradient(135deg, #ff2e74, #6d4aff);
  color: white;
}

.message {
  padding: 16px 20px;
  border-radius: 18px;
  margin-bottom: 18px;
  font-weight: 800;
}

.message.ok {
  background: #e8fff2;
  color: #087a3d;
  border: 1px solid #93efb8;
}

.message.error {
  background: #fff0f3;
  color: #b00035;
  border: 1px solid #ff9db6;
}

.step-content h2 {
  margin: 0 0 10px;
  font-size: 2rem;
}

.step-content p {
  color: #5f6b86;
  font-weight: 600;
}

.passenger-grid,
.baggage-list {
  display: grid;
  gap: 20px;
}

.form-card {
  background: #f8f9ff;
  border: 1px solid #e3e7fb;
  border-radius: 22px;
  padding: 22px;
}

.form-card h3 {
  margin: 0 0 18px;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

.form-grid label {
  display: flex;
  flex-direction: column;
  gap: 8px;
  color: #28344f;
  font-weight: 900;
}

.form-grid input,
.form-grid select,
.seat-select-list select {
  min-height: 50px;
  border: 1px solid #d8deea;
  border-radius: 14px;
  padding: 0 14px;
  outline: none;
  background: white;
}

.seat-wrapper {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 24px;
}

.plane-map {
  background: #f5f7ff;
  border-radius: 45px;
  padding: 24px;
  border: 2px dashed #cfd7f7;
}

.plane-nose {
  width: 70%;
  margin: 0 auto 18px;
  background: #12004d;
  color: white;
  padding: 14px;
  border-radius: 50px 50px 16px 16px;
  text-align: center;
  font-weight: 900;
}

.seat-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px 18px;
}

.seat {
  height: 42px;
  border: none;
  border-radius: 12px;
  background: white;
  color: #12004d;
  font-weight: 900;
  cursor: pointer;
  box-shadow: 0 8px 18px rgba(18, 0, 77, 0.08);
}

.seat.selected {
  background: linear-gradient(135deg, #ff2e74, #6d4aff);
  color: white;
}

.seat.blocked {
  background: #d7dbe8;
  color: #7b8195;
  cursor: not-allowed;
}

.seat-select-list {
  display: grid;
  gap: 14px;
}

.seat-select-list article {
  background: #f8f9ff;
  padding: 16px;
  border-radius: 18px;
  display: grid;
  gap: 10px;
}

.summary-box {
  display: grid;
  gap: 12px;
  background: #f8f9ff;
  border-radius: 22px;
  padding: 22px;
  margin-bottom: 22px;
}

.summary-box div {
  display: flex;
  justify-content: space-between;
  border-bottom: 1px solid #e1e5f3;
  padding-bottom: 10px;
}

.summary-total {
  font-size: 1.4rem;
  color: #ff2e74;
  border-bottom: none !important;
}

.mini-table {
  width: 100%;
  border-collapse: collapse;
  overflow: hidden;
  border-radius: 18px;
}

.mini-table th,
.mini-table td {
  padding: 14px;
  text-align: left;
  border-bottom: 1px solid #e6e9f5;
}

.mini-table th {
  background: #12004d;
  color: white;
}

.confirmation-card {
  background: #f3fff8;
  border: 1px solid #a5efc2;
  border-radius: 22px;
  padding: 24px;
  color: #075d31;
}

.flow-actions {
  display: flex;
  justify-content: flex-end;
  gap: 14px;
  margin-top: 28px;
}

.secondary-btn {
  padding: 16px 26px;
  background: #f2f4ff;
  color: #7a7292;
}

.primary-btn {
  padding: 16px 28px;
  background: linear-gradient(135deg, #ff2e74, #6d4aff);
  color: white;
  box-shadow: 0 12px 28px rgba(109, 74, 255, 0.25);
}

button:disabled {
  opacity: 0.55;
  cursor: not-allowed;
}

@media (max-width: 900px) {
  .flow-header,
  .route,
  .seat-wrapper {
    grid-template-columns: 1fr;
  }

  .flight-data,
  .steps,
  .form-grid {
    grid-template-columns: 1fr;
  }
}


/* ASIENTOS OCUPADOS DESDE BACKEND */
.seat.blocked {
  background: #ffe3ec !important;
  color: #a00035 !important;
  border: 2px solid #ff4fa0 !important;
  box-shadow: none !important;
  cursor: not-allowed !important;
  opacity: 1 !important;
  position: relative;
}

.seat.blocked::after {
  content: "×";
  position: absolute;
  top: -7px;
  right: -7px;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: #ff4fa0;
  color: white;
  display: grid;
  place-items: center;
  font-size: 12px;
  font-weight: 900;
}

.seat-legend {
  display: flex;
  gap: 14px;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 18px;
  color: #52617f;
  font-weight: 800;
}

.seat-legend span {
  display: inline-flex;
  align-items: center;
  gap: 7px;
}

.seat-legend i {
  width: 16px;
  height: 16px;
  border-radius: 5px;
  display: inline-block;
}

.seat-legend .free {
  background: #ffffff;
  border: 1px solid #d8deea;
}

.seat-legend .chosen {
  background: linear-gradient(135deg, #ff2e74, #6d4aff);
}

.seat-legend .busy {
  background: #ffe3ec;
  border: 1px solid #ff4fa0;
}

.seat-select-list option:disabled {
  color: #b00035;
  background: #ffe3ec;
}
